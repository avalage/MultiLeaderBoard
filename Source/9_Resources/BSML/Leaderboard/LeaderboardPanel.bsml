<horizontal pref-height="26" min-height="26" anchor-pos-y="5" pad-left="0" pad-right="5">
    <vertical pref-width="90" min-width="90" spacing="1">
        <horizontal pref-height="4">
            <macro.as-host host="status-bar">
                <macro.reparent transform="ui-component"/>
            </macro.as-host>
        </horizontal>

        <horizontal pref-height="21" spacing="1">
            <macro.as-host host="logo">
                <macro.reparent transform="ui-component"/>
            </macro.as-host>

            <macro.as-host host="player-info">
                <macro.reparent transform="ui-component"/>
            </macro.as-host>
        </horizontal>
    </vertical>
</horizontal>
